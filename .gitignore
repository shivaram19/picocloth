# =============================================================================
# PICO CLOTH — GLOBAL .gitignore
# This repository is designed to be OPEN and VISIBLE.
# We exclude only: secrets, runtime artifacts, generated files, and venvs.
# Everything else — architecture, docs, code, research — belongs to the world.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS & CREDENTIALS — NEVER COMMIT
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*secret*
*credential*
shared/state/langfuse-credentials.json

# ─────────────────────────────────────────────────────────────────────────────
# NODE RUNTIME — Generated during operation, not part of source
# ─────────────────────────────────────────────────────────────────────────────
# Active configs contain API keys and absolute paths.
# Use config.json.example templates + setup scripts to regenerate.
node-*/config.json
node-*/home/config.json
node-*/home/config.json.*.bak
node-*/home/.security.yml
node-*/home/.security.yml.*
node-*/home/.picoclaw.pid
node-*/home/logs/
node-*/node.log
node-*/pid
node-*/workspace/HEARTBEAT.md
node-*/workspace/cron/
node-*/workspace/sessions/
node-*/workspace/state/
node-*/workspace/shared/
node-*/workspace/linkedin-env/
node-*/workspace/linkedin-scraper/

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON — Virtual environments & cache
# ─────────────────────────────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
linkedin-env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ─────────────────────────────────────────────────────────────────────────────
# NODE.JS / PNPM / WEB UI
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─────────────────────────────────────────────────────────────────────────────
# GO — Build artifacts
# ─────────────────────────────────────────────────────────────────────────────
*.exe
*.dll
*.out
picoclaw
!picoclaw/           # keep the directory name if it exists

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────────────────────────────────────────
.env.docker
docker-compose.override.yml

# ─────────────────────────────────────────────────────────────────────────────
# IDE & EDITORS
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
*.code-workspace

# ─────────────────────────────────────────────────────────────────────────────
# TESTING & COVERAGE
# ─────────────────────────────────────────────────────────────────────────────
.coverage
.pytest_cache/
.tox/
.nox/
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ─────────────────────────────────────────────────────────────────────────────
# SHARED STATE — Runtime operational truth (generated by init + orchestrator)
# ─────────────────────────────────────────────────────────────────────────────
shared/state/fleet-state.json
shared/state/task-queue.json
shared/state/task-queue.jsonl
shared/state/task-queue.json.lock
shared/state/*.lock

# ─────────────────────────────────────────────────────────────────────────────
# SHARED PROJECT — Runtime artifacts and credentials
# ─────────────────────────────────────────────────────────────────────────────
shared/project/facts/*.lock
shared/project/facts/test_fact.json
shared/project/outreach/state/
shared/project/outreach/screenshots/
shared/project/outreach/logs/
shared/project/tools/linkedin-scraper/checkpoint_cookies.*
shared/project/tools/linkedin-scraper/body_dump.txt
shared/project/tools/linkedin-scraper/output.json
shared/project/tools/linkedin-scraper/outreach_log.jsonl
shared/project/tools/linkedin-scraper/outreach_progress.json
shared/project/tools/linkedin-scraper/outreach_stats.json
shared/project/tools/linkedin-scraper/obscura-src/
shared/project/tools/linkedin-scraper/screenshots/

# ─────────────────────────────────────────────────────────────────────────────
# WORKSPACE — Generated cross-node shared files
# ─────────────────────────────────────────────────────────────────────────────
workspace/shared/

# ─────────────────────────────────────────────────────────────────────────────
# BACKUPS & ARCHIVES (generated, not source)
# ─────────────────────────────────────────────────────────────────────────────
*.tar.gz
*.zip
backups/ram-opt-originals/*.orig
shared/compaction-archive/*/
shared/run/*/

# ─────────────────────────────────────────────────────────────────────────────
# LINKEDIN SCRAPER ARTIFACTS (top-level)
# ─────────────────────────────────────────────────────────────────────────────
linkedin-scraper/__pycache__/
linkedin-scraper/output.json
linkedin-scraper/body_dump.txt

# ─────────────────────────────────────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.pid
*.seed
*.pid.lock
.cache/
