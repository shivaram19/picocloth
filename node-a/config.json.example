{
  "version": 1,
  "agents": {
    "defaults": {
      "workspace": "{{PROJECT_ROOT}}/node-a/workspace",
      "restrict_to_workspace": false,
      "model_name": "grok-4.20-reasoning",
      "max_tokens": 2048,
      "max_tool_iterations": 3,
      "context_window": 32768,
      "steering_mode": "one-at-a-time",
      "system_prompt": "You are NODE-A, the Curiosity Brain - Research & query construction docs. RAM-optimized mode: concise responses, minimal tool calls.",
      "routing": {
        "enabled": true,
        "light_model": "grok-4.1-fast",
        "threshold": 0.4
      }
    }
  },
  "channel_list": {
    "pico": {
      "enabled": true,
      "type": "pico",
      "settings": {
        "ping_interval": 30,
        "read_timeout": 60,
        "write_timeout": 10,
        "max_connections": 5,
        "token": "fleet-token-node-a"
      }
    }
  },
  "model_list": [
    {
      "model_name": "grok-4.20-reasoning",
      "provider": "openai",
      "model": "grok-4.20-0309-reasoning",
      "api_base": "https://api.x.ai/v1",
      "api_keys": [
        "{{YOUR_XAI_API_KEY}}"
      ],
      "enabled": true
    },
    {
      "model_name": "grok-4.1-fast",
      "provider": "openai",
      "model": "grok-4-1-fast-non-reasoning",
      "api_base": "https://api.x.ai/v1",
      "api_keys": [
        "{{YOUR_XAI_API_KEY}}"
      ],
      "enabled": true
    }
  ],
  "gateway": {
    "host": "127.0.0.1",
    "port": 18790,
    "log_level": "warn"
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "hooks": {
    "enabled": true,
    "processes": {
      "digital_twin_guardian": {
        "enabled": true,
        "priority": 1,
        "command": [
          "{{PROJECT_ROOT}}/.venv/bin/python3",
          "{{PROJECT_ROOT}}/hooks/digital_twin_guardian.py"
        ],
        "env": {
          "FLEET_NODE_ID": "node-a",
          "PICOCLAW_HOOK_TWIN_DIR": "{{PROJECT_ROOT}}/shared/digital-twins/node-a",
          "PICOCLAW_HOOK_PROJECT_DIR": "{{PROJECT_ROOT}}/shared/project",
          "PICOCLAW_HOOK_MAX_FACTS": "4"
        },
        "observe": [
          "turn_end",
          "context_compress"
        ]
      }
    }
  },
  "tools": {
    "web": {
      "enabled": true,
      "provider": "duckduckgo"
    },
    "mcp": {
      "enabled": true,
      "servers": {
        "fleet_server": {
          "enabled": true,
          "command": "python3",
          "args": [
            "{{PROJECT_ROOT}}/mcp-fleet-server/server.py"
          ],
          "env": {
            "FLEET_NODE_ID": "node-a",
            "FLEET_SHARED_DIR": "{{PROJECT_ROOT}}/shared"
          }
        }
      }
    }
  }
}
